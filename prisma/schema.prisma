generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String            @id @default(uuid())
  name                String?
  email               String            @unique
  contact_number      String?           @unique
  avatar              String?
  status              UserStatus        @default(ACTIVE)
  role                UserRole          @default(USER)
  is_deleted          Boolean           @default(false)
  password_changed_at DateTime          @default(now())
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  books               Book[]
  transactions        Transaction[]
  goal_transactions   GoalTransaction[]
  categories          Category[]
  goals               Goal[]
  bookMembers         BookMember[]

  @@map("users")
}

model OTP {
  id         String   @id @default(uuid())
  email      String
  otp        Int      @unique
  expires_at String
  created_at DateTime @default(now())

  @@map("otps")
}

model Book {
  id         String   @id @default(uuid())
  name       String
  user_id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[]
  book_members BookMember[]

  @@map("books")
}

model BookMember {
  id         String    @id @default(uuid())
  book_id    String
  user_id    String
  role       ShareRole @default(VIEWER)
  created_at DateTime  @default(now())

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([book_id, user_id])
  @@map("book_members")
}

model Transaction {
  id          String          @id @default(uuid())
  book_id     String
  entry_by_id String
  amount      Decimal         @default(0)
  type        TransactionType
  remark      String?
  category_id String?
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  book     Book      @relation(fields: [book_id], references: [id])
  entry_by User      @relation(fields: [entry_by_id], references: [id])
  category Category? @relation(fields: [category_id], references: [id])

  @@map("transactions")
}

model Goal {
  id            String   @id @default(uuid())
  user_id       String
  name          String
  target_amount Decimal
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user         User              @relation(fields: [user_id], references: [id])
  transactions GoalTransaction[]

  @@map("goals")
}

model GoalTransaction {
  id          String          @id @default(uuid())
  goal_id     String
  entry_by_id String
  amount      Decimal         @default(0)
  type        TransactionType
  remark      String?
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  goal     Goal @relation(fields: [goal_id], references: [id], onDelete: Cascade)
  entry_by User @relation(fields: [entry_by_id], references: [id])

  @@map("goal_transactions")
}

model Category {
  id         String   @id @default(uuid())
  title      String
  icon       String?
  color      String?
  user_id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[]

  @@unique([user_id, title])
  @@map("categories")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum ShareRole {
  OWNER
  EDITOR
  VIEWER
}

enum TransactionType {
  IN
  OUT
}
