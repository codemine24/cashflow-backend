generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String        @id @default(uuid())
  name                String?
  email               String        @unique
  contact_number      String?       @unique
  avatar              String?
  status              UserStatus    @default(ACTIVE)
  role                UserRole      @default(USER)
  is_deleted          Boolean       @default(false)
  password_changed_at DateTime      @default(now())
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  books               Book[]
  transactions        Transaction[]
  categories          Category[]

  @@map("users")
}

model OTP {
  id         String   @id @default(uuid())
  email      String
  otp        Int      @unique
  expires_at String
  created_at DateTime @default(now())

  @@map("otps")
}

model Book {
  id         String   @id @default(uuid())
  name       String
  user_id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[]

  @@map("books")
}

model Transaction {
  id          String          @id @default(uuid())
  book_id     String
  entry_by_id String
  amount      Decimal         @default(0)
  type        TransactionType
  remark      String?
  category_id String?
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  book     Book      @relation(fields: [book_id], references: [id])
  entry_by User      @relation(fields: [entry_by_id], references: [id])
  category Category? @relation(fields: [category_id], references: [id])

  @@map("transactions")
}

model Category {
  id         String   @id @default(uuid())
  title      String
  icon       String?
  color      String?
  user_id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[]

  @@map("categories")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum TransactionType {
  INCOME
  EXPENSE
}
