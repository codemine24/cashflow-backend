generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Settings {
  id                String   @id @default(uuid())
  theme             Theme    @default(LIGHT)
  language          String   @default("english")
  currency          String   @default("BDT")
  push_notification Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("settings")
}

model User {
  id                  String     @id @default(uuid())
  name                String?
  email               String     @unique
  contact_number      String?    @unique
  avatar              String?
  status              UserStatus @default(ACTIVE)
  role                UserRole   @default(USER)
  is_deleted          Boolean    @default(false)
  password_changed_at DateTime   @default(now())
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  books                     Book[]
  entered_transactions      Transaction[]     @relation("EnteredTransactions")
  updated_transactions      Transaction[]     @relation("UpdatedTransactions")
  entered_goal_transactions GoalTransaction[] @relation("EnteredGoalTransactions")
  updated_goal_transactions GoalTransaction[] @relation("UpdatedGoalTransactions")
  goal_transactions         GoalTransaction[]
  categories                Category[]
  goals                     Goal[]
  books_member              BookMember[]
  goals_member              GoalMember[]
  files                     File[]
  subscriptions             Subscription[]
  notifications             Notification[]

  @@map("users")
}

model Subscription {
  id         String           @id @default(uuid())
  user_id    String
  plan       SubscriptionPlan
  price      Float
  start_date DateTime         @default(now())
  end_date   DateTime? // null = lifetime
  is_active  Boolean          @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("subscriptions")
}

model OTP {
  id         String   @id @default(uuid())
  email      String
  otp        Int      @unique
  expires_at String
  created_at DateTime @default(now())

  @@map("otps")
}

model Book {
  id         String   @id @default(uuid())
  name       String
  user_id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[]
  book_members BookMember[]

  @@map("books")
}

model BookMember {
  id         String    @id @default(uuid())
  book_id    String
  user_id    String
  role       ShareRole @default(VIEWER)
  created_at DateTime  @default(now())

  book Book @relation(fields: [book_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([book_id, user_id])
  @@map("book_members")
}

model Transaction {
  id           String          @id @default(uuid())
  book_id      String
  entry_by_id  String
  update_by_id String?
  amount       Decimal         @default(0)
  type         TransactionType
  remark       String?
  category_id  String?
  attachment   String[]        @default([])
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt

  book       Book      @relation(fields: [book_id], references: [id])
  entry_by   User      @relation("EnteredTransactions", fields: [entry_by_id], references: [id])
  updated_by User?     @relation("UpdatedTransactions", fields: [update_by_id], references: [id])
  category   Category? @relation(fields: [category_id], references: [id])

  @@map("transactions")
}

model Goal {
  id            String   @id @default(uuid())
  user_id       String
  name          String
  target_amount Decimal
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user         User              @relation(fields: [user_id], references: [id])
  transactions GoalTransaction[]
  goal_members GoalMember[]

  @@map("goals")
}

model GoalMember {
  id         String    @id @default(uuid())
  goal_id    String
  user_id    String
  role       ShareRole @default(VIEWER)
  created_at DateTime  @default(now())

  goal Goal @relation(fields: [goal_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([goal_id, user_id])
  @@map("goal_members")
}

model GoalTransaction {
  id           String          @id @default(uuid())
  goal_id      String
  entry_by_id  String
  update_by_id String?
  amount       Decimal         @default(0)
  type         TransactionType
  remark       String?
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt

  goal       Goal    @relation(fields: [goal_id], references: [id], onDelete: Cascade)
  entry_by   User    @relation("EnteredGoalTransactions", fields: [entry_by_id], references: [id])
  updated_by User?   @relation("UpdatedGoalTransactions", fields: [update_by_id], references: [id])
  user       User?   @relation(fields: [userId], references: [id])
  userId     String?

  @@map("goal_transactions")
}

model Category {
  id         String   @id @default(uuid())
  title      String
  icon       String?
  color      String?
  user_id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[]

  @@unique([user_id, title])
  @@map("categories")
}

model File {
  id          String   @id @default(uuid())
  user_id     String?
  name        String
  alt_text    String
  type        String
  size        Int
  width       Int
  height      Int
  path        String
  bucket_id   String
  bucket_name String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  uploaded_by User? @relation(fields: [user_id], references: [id])

  @@map("files")
}

model Notification {
  id           String   @id @default(uuid())
  user_id      String
  title        String
  message      String
  related_link String?
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum ShareRole {
  EDITOR
  VIEWER
}

enum TransactionType {
  IN
  OUT
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
  LIFETIME
}
